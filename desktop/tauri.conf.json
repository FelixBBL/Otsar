{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Otsar",
  "mainBinaryName": "Otsar",
  "version": "0.1.0",
  "identifier": "com.otsar.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Otsar",
        "width": 1100,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
